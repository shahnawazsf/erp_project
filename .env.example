# Oracle 12c Database Configuration
# Copy this file to .env and fill in your values

ORACLE_DB_HOST=localhost
ORACLE_DB_PORT=1521
ORACLE_DB_NAME=ORCL
ORACLE_DB_USER=erp_user
ORACLE_DB_PASSWORD=your_password_here

# Optional: Path to Oracle Instant Client (for thick mode / Oracle 12c full features)
# Example: C:\oracle\instantclient_21_10
ORACLE_CLIENT_DIR=
