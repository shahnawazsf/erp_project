# Oracle 12c Database Configuration
# Copy this file to .env and fill in your values

ORACLE_DB_HOST=172.16.1.12
ORACLE_DB_PORT=1521
ORACLE_DB_NAME=SDESDB
ORACLE_DB_USER=sdeserp
ORACLE_DB_PASSWORD=sdeserp


# Optional: Path to Oracle Instant Client (for thick mode / Oracle 12c full features)
# Example: C:\oracle\instantclient_21_10
ORACLE_CLIENT_DIR=C:\Oracle\client\Administrator\product\12.2.0\client_1\bin

# Anthropic Claude API key — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=
